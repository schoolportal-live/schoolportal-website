rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userRole() {
      return userData().role;
    }
    function userSchool() {
      return userData().schoolId;
    }
    function isPlatformAdmin() {
      return userRole() == 'platform_admin';
    }
    function isSchoolStaff(schoolId) {
      return request.auth != null
             && (isPlatformAdmin() || (userSchool() == schoolId && userRole() in ['super_admin', 'admin', 'line_manager', 'teacher', 'school_admin']));
    }
    function belongsToSchool(schoolId) {
      return request.auth != null
             && (isPlatformAdmin() || userSchool() == schoolId);
    }

    // ═══════════════════════════════════════════════════════════════════
    //   TOP-LEVEL COLLECTIONS (Legacy + Users + Platform)
    // ═══════════════════════════════════════════════════════════════════

    // ── Platform Config ─────────────────────────────────────────────
    match /platform/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (isPlatformAdmin() || userRole() == 'school_admin');
    }

    // ── Users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Staff can read all users (for name lookups, hierarchy, etc.)
      // Parents can read users from same school (for teacher names on homework/messages)
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || userRole() in ['school_admin', 'super_admin', 'platform_admin', 'admin', 'line_manager', 'teacher']
                      || (userRole() in ['parent', 'student'] && resource.data.schoolId == userSchool()));

      allow create: if request.auth != null
                    && (request.auth.uid == userId
                        || isPlatformAdmin()
                        || userRole() in ['super_admin', 'school_admin']);

      allow update: if request.auth != null
                    && (request.auth.uid == userId
                        || isPlatformAdmin()
                        || userRole() in ['super_admin', 'school_admin']);

      allow delete: if request.auth != null
                    && (isPlatformAdmin()
                        || userRole() in ['super_admin', 'school_admin']);
    }

    // ── Legacy Top-Level Collections (kept during migration) ─────────
    // These rules maintain backward compatibility with existing Phase 1-4 code.
    // They will be removed after Phase 3 migration to subcollections.

    match /notices/{noticeId} {
      allow read: if request.auth != null
                  && resource.data.schoolId == userSchool();
      allow create: if request.auth != null
                    && userRole() in ['school_admin', 'super_admin']
                    && request.resource.data.schoolId == userSchool();
      allow update, delete: if request.auth != null
                            && userRole() in ['school_admin', 'super_admin']
                            && resource.data.schoolId == userSchool();
    }

    match /submissions/{subId} {
      allow read: if request.auth != null
                  && userRole() in ['school_admin', 'super_admin', 'platform_admin'];
      allow create: if true;
      allow update, delete: if false;
    }

    match /parentForms/{formId} {
      allow read: if request.auth != null
                  && (resource.data.parentId == request.auth.uid
                      || (userRole() in ['school_admin', 'super_admin'] && resource.data.schoolId == userSchool()));
      allow create: if request.auth != null
                    && request.resource.data.parentId == request.auth.uid;
      allow update: if request.auth != null
                    && userRole() in ['school_admin', 'super_admin']
                    && resource.data.schoolId == userSchool();
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if request.auth != null
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.recipientId == request.auth.uid
                      || (userRole() in ['school_admin', 'super_admin'] && resource.data.schoolId == userSchool()));
      allow create: if request.auth != null
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.recipientId == request.auth.uid
                        || (userRole() in ['school_admin', 'super_admin'] && resource.data.schoolId == userSchool()));
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if request.auth != null
                  && resource.data.schoolId == userSchool();
      allow create, update, delete: if request.auth != null
                    && userRole() in ['school_admin', 'super_admin']
                    && resource.data.schoolId == userSchool();
    }

    // ═══════════════════════════════════════════════════════════════════
    //   SCHOOLS & SUBCOLLECTIONS (New Multi-Tenant Structure)
    // ═══════════════════════════════════════════════════════════════════

    match /schools/{schoolId} {
      // Anyone authenticated can read school doc (needed for branding on login)
      allow read: if request.auth != null;
      // Platform admin or school_admin (legacy, during migration) can manage schools
      allow create, update, delete: if request.auth != null
                   && (isPlatformAdmin() || userRole() == 'school_admin');

      // ── Classes ──────────────────────────────────────────────────
      match /classes/{classId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Sections ─────────────────────────────────────────────────
      match /sections/{sectionId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Students ─────────────────────────────────────────────────
      match /students/{studentId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
        allow delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'school_admin', 'platform_admin'];
      }

      // ── Hierarchy Positions ──────────────────────────────────────
      match /hierarchy/{positionId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'school_admin', 'platform_admin'];
      }

      // ── Notices (subcollection) ──────────────────────────────────
      match /notices/{noticeId} {
        allow read: if belongsToSchool(schoolId);
        allow create: if isSchoolStaff(schoolId);
        allow update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Messages (hierarchy-routed) ──────────────────────────────
      match /messages/{messageId} {
        allow read: if belongsToSchool(schoolId)
                    && (resource.data.senderId == request.auth.uid
                        || request.auth.uid in resource.data.recipientUids
                        || userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin']);
        allow create: if belongsToSchool(schoolId)
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if belongsToSchool(schoolId)
                      && (request.auth.uid in resource.data.recipientUids
                          || userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin']);
        allow delete: if false;
      }

      // ── Requests (hierarchy-routed, escalatable) ─────────────────
      match /requests/{requestId} {
        allow read: if belongsToSchool(schoolId)
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.parentId == request.auth.uid
                        || request.auth.uid in resource.data.recipientUids
                        || userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin']);
        allow create: if belongsToSchool(schoolId);
        allow update: if belongsToSchool(schoolId)
                      && (request.auth.uid in resource.data.recipientUids
                          || userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin']);
        allow delete: if false;
      }

      // ── Attendance ───────────────────────────────────────────────
      match /attendance/{recordId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isSchoolStaff(schoolId);
        allow delete: if false;
      }

      // ── Fees ─────────────────────────────────────────────────────
      match /fees/{feeId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
        allow delete: if false;
      }

      match /feePayments/{paymentId} {
        allow read: if belongsToSchool(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
        allow create, update: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
        allow delete: if false;
      }

      // ── Results ──────────────────────────────────────────────────
      match /results/{examId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'teacher', 'school_admin', 'platform_admin'];
        allow delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'school_admin', 'platform_admin'];
      }

      // ── Homework ─────────────────────────────────────────────────
      match /homework/{homeworkId} {
        allow read: if belongsToSchool(schoolId);
        allow create: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'teacher', 'school_admin', 'platform_admin'];
        allow update: if belongsToSchool(schoolId);  // Parents update completion, teachers verify
        allow delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'teacher', 'school_admin', 'platform_admin'];
      }

      // ── Requisitions ─────────────────────────────────────────────
      match /requisitions/{reqId} {
        allow read: if belongsToSchool(schoolId);
        allow create: if isSchoolStaff(schoolId);
        allow update: if isSchoolStaff(schoolId);
        allow delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'school_admin', 'platform_admin'];
      }

      match /requisitionCatalogue/{itemId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      match /paperRequisitions/{reqId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isSchoolStaff(schoolId);
        allow delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'school_admin', 'platform_admin'];
      }

      // ── Events ───────────────────────────────────────────────────
      match /events/{eventId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Transport ────────────────────────────────────────────────
      match /transport/{routeId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      match /transportRequests/{reqId} {
        allow read: if belongsToSchool(schoolId)
                    && (resource.data.parentId == request.auth.uid
                        || userRole() in ['super_admin', 'admin', 'school_admin', 'teacher', 'line_manager', 'platform_admin']);
        allow create: if belongsToSchool(schoolId);
        allow update: if isSchoolStaff(schoolId);
        allow delete: if false;
      }

      // ── Timetable ────────────────────────────────────────────────
      match /timetable/{sectionId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update, delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Library ──────────────────────────────────────────────────
      // Data path: library/books/items/{bookId}, library/transactions/items/{txnId}
      match /library/{category}/items/{itemId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'teacher', 'school_admin', 'platform_admin'];
        allow delete: if category == 'books' && isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Documents (student docs) ─────────────────────────────────
      match /documents/{docId} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if belongsToSchool(schoolId);
        allow delete: if isSchoolStaff(schoolId)
                    && userRole() in ['super_admin', 'admin', 'school_admin', 'platform_admin'];
      }

      // ── Medical Records ──────────────────────────────────────────
      match /medicalRecords/{recordId} {
        allow read: if belongsToSchool(schoolId);
        allow create: if belongsToSchool(schoolId);  // Parents can submit for approval
        allow update: if isSchoolStaff(schoolId);     // Staff approves/rejects
        allow delete: if false;                       // Never delete medical records
      }

      // ── Notifications ────────────────────────────────────────────
      match /notifications/{notifId} {
        allow read: if belongsToSchool(schoolId)
                    && resource.data.uid == request.auth.uid;
        allow create: if belongsToSchool(schoolId);
        allow update: if belongsToSchool(schoolId)
                      && resource.data.uid == request.auth.uid;
        allow delete: if false;
      }
    }

    // ── Default deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
