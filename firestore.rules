rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: get user role ────────────────────────────────────────
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function userSchool() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId;
    }

    // ── Users collection ──────────────────────────────────────────
    match /users/{userId} {
      // Admins can read all users in their school; users can read own doc
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || userRole() == 'school_admin');

      // Users can create their own document at signup
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role in ['school_admin', 'parent']
                    && request.resource.data.keys().hasAll(['role', 'email', 'displayName', 'createdAt']);

      // Users can update their own doc but CANNOT change their role
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;

      // Only admins can delete parent users (from same school)
      allow delete: if request.auth != null
                    && userRole() == 'school_admin'
                    && resource.data.role == 'parent';
    }

    // ── Notices collection ────────────────────────────────────────
    match /notices/{noticeId} {
      // Anyone authenticated in the same school can read notices
      allow read: if request.auth != null
                  && resource.data.schoolId == userSchool();

      // Only school_admin can create notices
      allow create: if request.auth != null
                    && userRole() == 'school_admin'
                    && request.resource.data.schoolId == userSchool()
                    && request.resource.data.keys().hasAll(['title', 'body', 'authorId', 'schoolId', 'createdAt']);

      // Only school_admin can update/delete notices in their school
      allow update, delete: if request.auth != null
                            && userRole() == 'school_admin'
                            && resource.data.schoolId == userSchool();
    }

    // ── Submissions collection ────────────────────────────────────
    match /submissions/{subId} {
      // Admins can read all submissions
      allow read: if request.auth != null
                  && userRole() == 'school_admin';

      // Anyone can create a submission (public forms)
      allow create: if true;

      // No client-side update/delete
      allow update, delete: if false;
    }

    // ── Default deny all ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
